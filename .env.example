# Telegram group
# Existing bot: paste the existing group/private chat id here.
# New bot/group: use npm run telegram:ids after sending a message to the bot/group.
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_GROUP_ALLOWED_CHATS=
TELEGRAM_ALLOWED_USERS=

# Topic IDs / message_thread_id
OPERATOR_TOPIC_ID=
SCREENING_TOPIC_ID=
ANALYST_TOPIC_ID=
SYSTEM_TOPIC_ID=
RESULT_TOPIC_ID=
ENTRY_TOPIC_ID=
TRADE_LOG_TOPIC_ID=
TROUBLESHOOT_TOPIC_ID=

# Bot usernames
LIO_TELEGRAM_BOT_USERNAME=@Liocala_bot
CALA_TELEGRAM_BOT_USERNAME=@Calalio_bot
KONLIN_TELEGRAM_BOT_USERNAME=@KOnlin_bot

# Bot tokens
LIO_TELEGRAM_BOT_TOKEN=
CALA_TELEGRAM_BOT_TOKEN=
KONLIN_TELEGRAM_BOT_TOKEN=

# Main gateway
TELEGRAM_GATEWAY_AGENT=Lio

# Models
AGENT_OPERATOR_PROVIDER=deepseek
AGENT_SCREENING_PROVIDER=deepseek
AGENT_ANALYST_PROVIDER=anthropic

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_OPERATOR_MODEL=deepseek-chat
DEEPSEEK_SCREENING_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
CLAUDE_ANALYST_MODEL=claude-sonnet-4-6

# Meteora
METEORA_API_BASE_URL=https://dlmm-api.meteora.ag

# Local database
DATABASE_PATH=./data/meteora-dlmm.sqlite

# Safe mode defaults
EXECUTION_MODE=SCANNER_ONLY
PAPER_TRADING=true
ENABLE_REAL_EXECUTION=false
EMERGENCY_STOP=false

# Scanner config
SCAN_INTERVAL_MINUTES=5
MIN_TVL=20000
MIN_VOLUME_24H=50000
MIN_FEE_TVL_RATIO_24H=0.005
MIN_POOL_AGE_HOURS=12

ALERT_SCORE_THRESHOLD=70
CLAUDE_CONFIDENCE_THRESHOLD=70
MAX_CLAUDE_POOL_COUNT=5
MAX_ALERTS_PER_SCAN=3
DUPLICATE_ALERT_COOLDOWN_MINUTES=30

# Position management (simulated in scanner/dry-run mode)
# Daily kill-switch threshold; HERON maps its maxDailyDrawdownPct here.
MAX_DAILY_DRAWDOWN_PCT=10
# Simulated notional per paper position for net-PnL estimates.
PAPER_NOTIONAL_USD=1000
# Net-PnL / OOR / kill-switch cycle. Defaults to the Meridian preset value.
#MANAGEMENT_INTERVAL_MINUTES=10
MANAGEMENT_CYCLE_ENABLED=true
# Public address only (read-only startup reconciliation). Never a private key.
WALLET_PUBLIC_ADDRESS=

# Strategy profile used for Konlin analyst prompts and breakdown-watch wiring.
# EVILPANDA (default) | HERON | DEFAULT
STRATEGY_PROFILE=EVILPANDA

# Meridian integration
MERIDIAN_ENGINE_PATH=../meridian-upstream
MERIDIAN_SAFE_CONFIG_PATH=./config/meridian-safe.config.json
MERIDIAN_PRESET=moderate
DRY_RUN=true

# Meridian live full-auto-small requirements
# Do not paste private keys in Telegram or chat. Put local-only secrets in .env.
WALLET_PRIVATE_KEY=
RPC_URL=
OPENROUTER_API_KEY=
HELIUS_API_KEY=
LPAGENT_API_KEY=

# Optional OpenRouter models used by Meridian
OPENROUTER_MANAGEMENT_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SCREENING_MODEL=deepseek/deepseek-chat
OPENROUTER_GENERAL_MODEL=deepseek/deepseek-chat
